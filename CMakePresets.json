{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "displayName": "Base Config",
            "description": "Base configuration with common settings",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build"
        },
        {
            "name": "release",
            "displayName": "Release Build",
            "description": "Release build configuration (optimized)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug Build",
            "description": "Debug build configuration (with debug symbols)",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "relwithdebinfo",
            "displayName": "Release with Debug Info",
            "description": "Optimized build with debug symbols",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "coverage",
            "displayName": "Coverage Build",
            "description": "Debug build with source-based coverage instrumentation (clang)",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build-coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_COVERAGE": "ON"
            }
        },
        {
            "name": "asan",
            "displayName": "ASan + UBSan Build",
            "description": "Debug build with AddressSanitizer and UndefinedBehaviorSanitizer",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build-asan",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_SANITIZERS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "relwithdebinfo",
            "configurePreset": "relwithdebinfo"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage"
        },
        {
            "name": "asan",
            "configurePreset": "asan"
        }
    ],
    "testPresets": [
        {
            "name": "release",
            "configurePreset": "release"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "relwithdebinfo",
            "configurePreset": "relwithdebinfo"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage"
        },
        {
            "name": "asan",
            "configurePreset": "asan"
        }
    ]
}
